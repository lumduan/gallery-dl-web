# Copy to .env and adjust. Cookies are NEVER set here — manage them via the Settings UI
# (stored only in /data/cookies.json, mode 0600, gitignored).

APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

DATA_DIR=/data
DOWNLOADS_DIR=/data/downloads
COOKIES_PATH=/data/cookies.json

# Comma-separated origins allowed by CORS (the Next.js frontend).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MAX_CONCURRENT_JOBS=2

# Profile management: seconds a generated profile .zip lives after last access; thumbnail longest-side px.
ZIP_TTL_SECONDS=300
THUMBNAIL_SIZE=300
# Auto-stop a job left paused this long (a paused worker stays suspended in memory). 0 = never.
PAUSE_MAX_SECONDS=7200

# Stall detection + retry: a download with no file events for too long is killed and retried.
# Threshold = clamp(floor*backoff^attempt, multiplier*avg_inter_file, cap).
HTTP_TIMEOUT_SECONDS=30
STALL_FLOOR_SECONDS=90
STALL_MULTIPLIER=4
STALL_CAP_SECONDS=600
STALL_MAX_RETRIES=2
STALL_BACKOFF=1.5
STALL_KILL_GRACE_SECONDS=10
