# Root-level defaults for docker compose (copy to .env). Cookie values are NEVER set here —
# manage them at runtime via the Settings UI (stored only in /data/cookies.json).

# Ports published to the host
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000

# Where downloaded media lives (an in-container path under the /data volume).
#
# To use a HOST directory instead (e.g. a NAS share), set it here AND enable the bind-mount
# overlay by uncommenting COMPOSE_FILE below — the variable alone does nothing, because the path
# still has to exist inside the container:
#   DOWNLOADS_DIR=/mnt/downloads/gallery
#   COMPOSE_FILE=docker-compose.yml:docker-compose.hostdir.yml
DOWNLOADS_DIR=/data/downloads
# COMPOSE_FILE=docker-compose.yml:docker-compose.hostdir.yml

# Comma-separated origins the backend allows via CORS (the frontend origin).
CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=INFO
MAX_CONCURRENT_JOBS=2

# Profile management
ZIP_TTL_SECONDS=300
THUMBNAIL_SIZE=300
# Auto-stop a job left paused this long (a paused worker stays suspended in memory). 0 = never.
PAUSE_MAX_SECONDS=7200

# Per-request pacing (gallery-dl `sleep-request`, seconds; a range sampled per request).
# Both platforms rate-limit scraping — Facebook blocks an account after a few hundred images
# fetched back-to-back. RAISE these if you get blocked; set MAX to 0 to disable pacing.
INSTAGRAM_SLEEP_REQUEST_MIN=6
INSTAGRAM_SLEEP_REQUEST_MAX=12
FACEBOOK_SLEEP_REQUEST_MIN=3
FACEBOOK_SLEEP_REQUEST_MAX=8

# Stall detection + retry. Two independent deadlines, see docs/event-contract.md:
#   liveness — no worker output at all (not even a heartbeat) => the process is wedged
#   progress — no *file* event. Before the first file this is the WARM-UP budget, because
#              gallery-dl is silent while enumerating a profile (Instagram sleeps 6-12s per
#              request). After the first file:
#              clamp(floor*backoff^attempt, multiplier*avg_inter_file, cap)
HTTP_TIMEOUT_SECONDS=30
HEARTBEAT_SECONDS=15
STALL_LIVENESS_SECONDS=60
STALL_WARMUP_SECONDS=600
STALL_WARMUP_MAX_RETRIES=1
STALL_FLOOR_SECONDS=300
STALL_MULTIPLIER=4
STALL_CAP_SECONDS=600
STALL_MAX_RETRIES=2
STALL_BACKOFF=1.5
STALL_KILL_GRACE_SECONDS=10
